{
   "name": "sql-performance-lab",
   "version": "1.0.0",
   "description": "",
   "main": "index.js",
   "scripts": {
      "test": "vitest run",
      "test:watch": "vitest",
      "build": "tsc -p .",
      "start": "node dist/server.js",
      "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
      "migrate": "knex --knexfile src/knexfile.ts migrate:latest",
      "migrate:rollback": "knex --knexfile src/knexfile.ts migrate:rollback",
      "migrate:make": "knex --knexfile src/knexfile.ts migrate:make",
      "seed:make": "knex --knexfile src/knexfile.ts seed:make",
      "seed:run": "knex --knexfile src/knexfile.ts seed:run"
   },
   "keywords": [],
   "author": "",
   "license": "ISC",
   "packageManager": "pnpm@10.22.0",
   "dependencies": {
      "dotenv": "^17.3.1",
      "express": "^5.2.1",
      "knex": "^3.2.7",
      "pg": "^8.20.0"
   },
   "devDependencies": {
      "@faker-js/faker": "^10.4.0",
      "@types/express": "^5.0.6",
      "@types/node": "^25.5.0",
      "@types/supertest": "^7.2.0",
      "supertest": "^7.2.2",
      "ts-node": "^10.9.2",
      "ts-node-dev": "^2.0.0",
      "typescript": "^6.0.2",
      "vitest": "^4.1.2"
   },
   "vitest": {
      "environment": "node"
   }
}
