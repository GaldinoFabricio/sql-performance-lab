{
   "compilerOptions": {
      "target": "es2020",
      "module": "commonjs",
      "lib": ["es2020"],
      "allowJs": true,
      "outDir": "build",
      "rootDir": ".",
      "strict": true,
      "noImplicitAny": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "types": ["node"]
   },
   "include": ["src", "knexfile.ts"],
   "exclude": ["node_modules", "dist", "test", "eslint.config.mjs"]
}
