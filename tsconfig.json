{
   "compilerOptions": {
      "target": "es2020",
      "module": "commonjs",
      "lib": ["es2020"],
      "allowJs": true,
      "outDir": "dist",
      "rootDir": "src",
      "strict": true,
      "noImplicitAny": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "types": ["node"]
   },
   "include": ["src"],
   "exclude": [
      "node_modules",
      "dist",
      "test",
      "eslint.config.mjs",
      "src/**/*.test.ts"
   ]
}
